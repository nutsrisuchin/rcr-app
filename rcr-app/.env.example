# RCR App - Environment Variables Template
# Copy this file to .env and fill in the values

# Node Environment
NODE_ENV=production

# Application Port
PORT=8080

# API Configuration (if applicable)
# REACT_APP_API_BASE_URL=https://api.example.com

# Database Configuration (if applicable)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rcr_db
# DB_USER=root
# DB_PASSWORD=

# Google Cloud Configuration
# GCP_PROJECT_ID=your-project-id
# GCP_SERVICE_ACCOUNT_EMAIL=rcr-app-service@your-project-id.iam.gserviceaccount.com

# Application Secrets (if applicable)
# API_KEY=
# SECRET_KEY=

# Logging
# LOG_LEVEL=info
